# Your VPS IP or hostname
DSVPN_SERVER=change-me

# DSVPN server port (must match the server)
DSVPN_PORT=443

# DNS server for resolution outside the VPN tunnel
DNS_SERVER=88.198.92.222

# Transmission user ID and group ID (match your host user)
PUID=1000
PGID=1000

# Timezone
TZ=Etc/UTC

# Torrent peer port
PEERPORT=51413

# Transmission web UI credentials
USER=youruser
PASS=yourpassword
